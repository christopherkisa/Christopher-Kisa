# Public site URL (used for metadata, JSON-LD, Open Graph)
NEXT_PUBLIC_SITE_URL=https://your-project.pages.dev

# Cloudflare Turnstile — https://developers.cloudflare.com/turnstile/
# Widget (visible in browser)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Secret (server only — *never* expose to the client)
TURNSTILE_SECRET_KEY=

# Google Maps Embed API (optional) — https://developers.google.com/maps/documentation/embed/get-started
# Leave blank to use basic maps embed (no API key required)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

